{
  "name": "clawpilot",
  "publisher": "clawpilot",
  "displayName": "ClawPilot",
  "description": "Local AI coding assistant powered by Ollama — chat, inline completions, code actions, git tools, and more.",
  "version": "1.0.1",
  "icon": "assets/icon.png",
  "license": "MIT",
  "homepage": "https://github.com/abhiramvishal/Ollama-Agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhiramvishal/Ollama-Agent"
  },
  "bugs": {
    "url": "https://github.com/abhiramvishal/Ollama-Agent/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ollama",
    "copilot",
    "ai",
    "llm",
    "local",
    "completion",
    "chat",
    "codellama"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clawpilot.openChat",
        "title": "ClawPilot: Open Chat"
      },
      {
        "command": "clawpilot.setup",
        "title": "ClawPilot: Setup / Install Local AI"
      },
      {
        "command": "clawpilot.explainCode",
        "title": "ClawPilot: Explain Code"
      },
      {
        "command": "clawpilot.refactorCode",
        "title": "ClawPilot: Refactor Code"
      },
      {
        "command": "clawpilot.fixCode",
        "title": "ClawPilot: Fix Bugs"
      },
      {
        "command": "clawpilot.generateDocs",
        "title": "ClawPilot: Generate Docs"
      },
      {
        "command": "clawpilot.reviewCode",
        "title": "ClawPilot: Code Review"
      },
      {
        "command": "clawpilot.optimizeCode",
        "title": "ClawPilot: Optimize Code"
      },
      {
        "command": "clawpilot.writeTests",
        "title": "ClawPilot: Write Tests"
      },
      {
        "command": "clawpilot.addTypes",
        "title": "ClawPilot: Add TypeScript Types"
      },
      {
        "command": "clawpilot.editFile",
        "title": "ClawPilot: Edit File (Agent)"
      },
      {
        "command": "clawpilot.planFeature",
        "title": "ClawPilot: Plan Feature (Agent)"
      },
      {
        "command": "clawpilot.runCommand",
        "title": "ClawPilot: Run Terminal Command (Agent)"
      },
      {
        "command": "clawpilot.selectModel",
        "title": "ClawPilot: Select Model"
      },
      {
        "command": "clawpilot.pullModel",
        "title": "ClawPilot: Pull Model"
      },
      {
        "command": "clawpilot.reindexWorkspace",
        "title": "ClawPilot: Re-index Workspace"
      },
      {
        "command": "clawpilot.clearMemory",
        "title": "ClawPilot: Clear Agent Memory"
      },
      {
        "command": "clawpilot.viewMemory",
        "title": "ClawPilot: View / Edit Memory"
      },
      {
        "command": "clawpilot.explain",
        "title": "ClawPilot: Explain Selection"
      },
      {
        "command": "clawpilot.refactor",
        "title": "ClawPilot: Refactor Selection"
      },
      {
        "command": "clawpilot.fix",
        "title": "ClawPilot: Fix Bugs in Selection"
      },
      {
        "command": "clawpilot.add_tests",
        "title": "ClawPilot: Add Tests for Selection"
      },
      {
        "command": "clawpilot.add_docs",
        "title": "ClawPilot: Add Docs to Selection"
      },
      {
        "command": "clawpilot.codeLensAction",
        "title": "ClawPilot: Code Lens Action"
      },
      {
        "command": "clawpilot.toggleCompletions",
        "title": "ClawPilot: Toggle Inline Completions"
      },
      {
        "command": "clawpilot.fixDiagnostic",
        "title": "ClawPilot: Fix Diagnostic"
      },
      {
        "command": "clawpilot.newSession",
        "title": "ClawPilot: New Chat Session",
        "icon": "$(add)"
      },
      {
        "command": "clawpilot.switchSession",
        "title": "ClawPilot: Switch Session",
        "icon": "$(history)"
      },
      {
        "command": "clawpilot.clearSession",
        "title": "ClawPilot: Clear Current Session",
        "icon": "$(clear-all)"
      },
      {
        "command": "clawpilot.exportSession",
        "title": "ClawPilot: Export Session to Markdown",
        "icon": "$(export)"
      },
      {
        "command": "clawpilot.askGitStatus",
        "title": "ClawPilot: Summarise Git Status"
      },
      {
        "command": "clawpilot.selectProvider",
        "title": "ClawPilot: Select Provider"
      },
      {
        "command": "clawpilot.manageApiKeys",
        "title": "ClawPilot: Manage API Keys"
      },
      {
        "command": "clawpilot.doctor",
        "title": "ClawPilot: System Diagnostics"
      },
      {
        "command": "clawpilot.toggleProxy",
        "title": "ClawPilot: Toggle Local Proxy"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clawpilot",
          "title": "ClawPilot",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "clawpilot": [
        {
          "type": "webview",
          "id": "clawpilot.chatView",
          "name": "Chat"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "clawpilot.newSession",
          "when": "view == clawpilot.chatView",
          "group": "navigation@1"
        },
        {
          "command": "clawpilot.switchSession",
          "when": "view == clawpilot.chatView",
          "group": "navigation@2"
        },
        {
          "command": "clawpilot.clearSession",
          "when": "view == clawpilot.chatView",
          "group": "navigation@3"
        },
        {
          "command": "clawpilot.exportSession",
          "when": "view == clawpilot.chatView",
          "group": "navigation@4"
        }
      ],
      "editor/context": [
        {
          "command": "clawpilot.explain",
          "when": "editorHasSelection",
          "group": "clawpilot@1"
        },
        {
          "command": "clawpilot.refactor",
          "when": "editorHasSelection",
          "group": "clawpilot@2"
        },
        {
          "command": "clawpilot.fix",
          "when": "editorHasSelection",
          "group": "clawpilot@3"
        },
        {
          "command": "clawpilot.add_tests",
          "when": "editorHasSelection",
          "group": "clawpilot@4"
        },
        {
          "command": "clawpilot.add_docs",
          "when": "editorHasSelection",
          "group": "clawpilot@5"
        },
        {
          "command": "clawpilot.explainCode",
          "when": "editorHasSelection",
          "group": "clawpilot@1"
        },
        {
          "command": "clawpilot.fixCode",
          "when": "editorHasSelection",
          "group": "clawpilot@2"
        },
        {
          "command": "clawpilot.refactorCode",
          "when": "editorHasSelection",
          "group": "clawpilot@3"
        },
        {
          "command": "clawpilot.reviewCode",
          "when": "editorHasSelection",
          "group": "clawpilot@4"
        },
        {
          "command": "clawpilot.writeTests",
          "when": "editorHasSelection",
          "group": "clawpilot@5"
        },
        {
          "command": "clawpilot.generateDocs",
          "when": "editorHasSelection",
          "group": "clawpilot@6"
        },
        {
          "command": "clawpilot.editFile",
          "when": "editorIsOpen",
          "group": "clawpilot@7"
        }
      ],
      "editor/title": [
        {
          "command": "clawpilot.editFile",
          "when": "editorIsOpen",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "ClawPilot",
      "properties": {
        "clawpilot.provider": {
          "type": "string",
          "enum": ["ollama", "lmstudio", "llamafile", "vllm", "localai", "jan", "textgen-webui", "openai-compatible", "anthropic", "openai", "google"],
          "enumDescriptions": [
            "Ollama (localhost:11434)",
            "LM Studio (localhost:1234)",
            "llamafile (localhost:8080)",
            "vLLM (localhost:8000)",
            "LocalAI (localhost:8080)",
            "Jan (localhost:1337)",
            "Text Generation WebUI / oobabooga (localhost:5000)",
            "Any OpenAI-compatible server (uses clawpilot.endpoint)",
            "Anthropic Claude (API key required)",
            "OpenAI GPT (API key required)",
            "Google Gemini (API key required)"
          ],
          "default": "ollama",
          "description": "Which LLM provider to use. Local providers are free; API providers require keys (ClawPilot: Manage API Keys)."
        },
        "clawpilot.preferLocal": {
          "type": "boolean",
          "default": true,
          "description": "Always try local providers first; fall back to API only if local provider is unavailable."
        },
        "clawpilot.autoDetectProvider": {
          "type": "boolean",
          "default": false,
          "description": "On startup, scan for running local LLM servers and auto-select the first one found."
        },
        "clawpilot.endpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server endpoint URL (also used for openai-compatible when no provider-specific endpoint is set)"
        },
        "clawpilot.lmstudioEndpoint": {
          "type": "string",
          "default": "http://localhost:1234",
          "description": "LM Studio API endpoint."
        },
        "clawpilot.llamafileEndpoint": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "llamafile API endpoint."
        },
        "clawpilot.vllmEndpoint": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "vLLM API endpoint."
        },
        "clawpilot.localaiEndpoint": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "LocalAI API endpoint."
        },
        "clawpilot.janEndpoint": {
          "type": "string",
          "default": "http://localhost:1337",
          "description": "Jan API endpoint."
        },
        "clawpilot.textgenEndpoint": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "Text Generation WebUI (oobabooga) API endpoint."
        },
        "clawpilot.model": {
          "type": "string",
          "default": "llama3",
          "description": "Model to use for chat, agent mode, and completions"
        },
        "clawpilot.agentMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable agent mode by default (allows file editing, terminal access, and multi-step task execution)"
        },
        "clawpilot.enableInlineCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Enable Copilot-style inline code completions"
        },
        "clawpilot.codeLensEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show ClawPilot Code Lens above functions and classes."
        },
        "clawpilot.inlineCompletionsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show ClawPilot ghost-text inline completions as you type."
        },
        "clawpilot.completionDebounceMs": {
          "type": "number",
          "default": 600,
          "description": "Debounce delay (ms) before requesting an inline completion"
        },
        "clawpilot.maxTokens": {
          "type": "number",
          "default": 2048,
          "description": "Maximum tokens for chat responses (completions use a separate lower limit)"
        },
        "clawpilot.completionMaxTokens": {
          "type": "number",
          "default": 256,
          "description": "Maximum tokens for inline completions"
        },
        "clawpilot.systemPrompt": {
          "type": "string",
          "default": "You are an expert coding assistant. Be concise, accurate, and helpful.",
          "description": "Custom system prompt for chat mode (agent mode uses its own system prompt)"
        },
        "clawpilot.agentMaxIterations": {
          "type": "number",
          "default": 15,
          "description": "Maximum tool-call iterations before agent stops"
        },
        "clawpilot.embeddingModel": {
          "type": "string",
          "default": "nomic-embed-text",
          "description": "Ollama embedding model for RAG (e.g. nomic-embed-text). If not available, keyword (BM25) fallback is used."
        },
        "clawpilot.ragEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable workspace RAG: inject relevant code context into chat from semantic search"
        },
        "clawpilot.ragTopK": {
          "type": "number",
          "default": 5,
          "description": "Number of top code chunks to inject into the prompt from RAG"
        },
        "clawpilot.ragHybridAlpha": {
          "type": "number",
          "default": 0.6,
          "description": "Hybrid RAG scoring: weight for vector similarity (0-1). Score = alpha * vectorScore + (1-alpha) * normalizedBM25. 0.6 = 60% vector, 40% keyword."
        },
        "clawpilot.fallbackModels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Ordered list of fallback Ollama models to try if the primary model fails"
        },
        "clawpilot.proxyEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the local ClawPilot proxy that exposes an OpenAI-compatible completion/chat API on a configurable port"
        },
        "clawpilot.proxyPort": {
          "type": "number",
          "default": 11435,
          "description": "Port for the ClawPilot local proxy server (OpenAI-compatible API). Restart VS Code or toggle the proxy to apply changes."
        },
        "clawpilot.memoryEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable persistent memory across sessions (core, recall, archival)"
        },
        "clawpilot.autoSaveMemory": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save conversation summaries to recall memory"
        },
        "clawpilot.recallTopK": {
          "type": "number",
          "default": 3,
          "description": "Number of recall memory entries to inject per message"
        },
        "clawpilot.reflexionMaxRetries": {
          "type": "number",
          "default": 3,
          "description": "Maximum self-correction retries when a tool call fails (Reflexion loop). Set to 0 to disable."
        },
        "clawpilot.diffPreviewEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a diff preview before the agent applies file changes."
        }
      }
    },
    "keybindings": [
      {
        "command": "clawpilot.openChat",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o"
      },
      {
        "command": "clawpilot.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "clawpilot.fixCode",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorHasSelection"
      },
      {
        "command": "clawpilot.editFile",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorIsOpen"
      },
      {
        "command": "clawpilot.planFeature",
        "key": "ctrl+shift+p",
        "mac": "cmd+shift+p"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "bundle": "node esbuild.js",
    "bundle:prod": "node esbuild.js --production",
    "watch": "tsc -p ./ --watch",
    "package": "npm run bundle:prod && vsce package --no-dependencies",
    "vscode:prepublish": "npm run bundle:prod"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.3.0"
  }
}
